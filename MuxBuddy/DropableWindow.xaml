<ui:FluentWindow x:Class="MuxBuddy.DropableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        WindowBackdropType="Mica"
        Background="Transparent"
        WindowStyle="None"
        ExtendsContentIntoTitleBar="True"
        Title="Mux Buddy"
        AllowDrop="True"
        Drop="MainWindow_OnDrop"
        DragEnter="Window_DragEnter"
        DragLeave="Window_DragLeave"
        Height="400" MaxHeight="800" MinHeight="300"
        Width="300" MaxWidth="400" MinWidth="300"
        ResizeMode="NoResize">
    <Window.TaskbarItemInfo>
        <TaskbarItemInfo x:Name="TaskbarInfo"/>
    </Window.TaskbarItemInfo>
    <Grid Background="Transparent">
        <Border x:Name="DropOverlay"
                Background="#AA000000"
                Opacity="1"
                Visibility="Collapsed">
            <TextBlock Text="Drop items here"
                       Foreground="White"
                       FontSize="22"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontWeight="Bold"/>
        </Border>
        <ui:TitleBar
            x:Name="TitleBar"
            Title="Mux Buddy"
            Height="32"
            ShowMinimize="True"
            ShowMaximize="False"
            ShowClose="True"/>
        <Grid Margin="0,32,0,0">
                <Grid>
                    <ScrollViewer x:Name="VideoViewPanel" Margin="0,0,0,40" Visibility="Visible">
                        <StackPanel Margin="5" VerticalAlignment="Top" HorizontalAlignment="Stretch" Orientation="Vertical">
                            <TextBlock Text="Video Input" Margin="5,-5,5,2.5" FontWeight="Medium" FontSize="14" FontFamily="Segoe UI Variable"/>
                            <ui:Card>
                                <StackPanel>
                                    <TextBlock x:Name="VideoPathTrace" TextWrapping="Wrap" Text="Drop a video to start"/>
                                    <StackPanel x:Name="VideoBeforeDataPanel" Visibility="Collapsed">
                                    <Separator Margin="0,2.5"/>
                                    <UniformGrid Columns="3">
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="Video"/>
                                            <TextBlock x:Name="VideoBeforeBitRate" Text="0Kbps"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="Audio"/>
                                            <TextBlock x:Name="VideoBeforeAudioBitrate" Text="0Kbps"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="Total"/>
                                            <TextBlock x:Name="VideoBeforeTotalBitrate" Text="0Kbps"/>
                                        </StackPanel>
                                    </UniformGrid>
                                    <UniformGrid Columns="3" Margin="0,5,0,0">
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="Size"/>
                                            <TextBlock x:Name="VideoBeforeSize" Text="0MB"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="Streams"/>
                                            <TextBlock x:Name="VideoBeforeAudioCount" Text="0"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="Duration"/>
                                            <TextBlock x:Name="VideoBeforeDuration" Text="0"/>
                                        </StackPanel>
                                    </UniformGrid>
                                    <UniformGrid Columns="2" Margin="0,5,0,-2.5">
                                        <UniformGrid.Resources>
                                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                            </Style>
                                        </UniformGrid.Resources>
                                        <ui:Button Margin="0,0,2.5,0" Click="OpenVideo_OnClick" Content="Open Video"/>
                                        <ui:Button Margin="2.5,0,0,0" Click="OpenInExporer_OnClick" Content="Open in Explorer"/>
                                    </UniformGrid>
                                    </StackPanel>
                                </StackPanel>
                            </ui:Card>
                            <StackPanel x:Name="VideoEncoderPropertiesPanel" Visibility="Collapsed">
                                <TextBlock Text="Time" Margin="5,2.5" FontWeight="Medium" FontSize="14" FontFamily="Segoe UI Variable"/>
                                <ui:Card x:Name="VideoTimeSpan">
                                <UniformGrid Columns="2">
                                    <UniformGrid.Resources>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Margin" Value="2.5,0"/>
                                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                        </Style>
                                    </UniformGrid.Resources>
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Text="Start"/>
                                        <ui:NumberBox x:Name="VideoStartTimeNumberBox" ValueChanged="VideoStartTime_OnValueChanged" SpinButtonPlacementMode="Hidden" Minimum="0"/>
                                        <TextBlock x:Name="VideoStartTimeTxt"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Text="End"/>
                                        <ui:NumberBox x:Name="VideoEndTimeNumberBox" ValueChanged="VideoEndTime_OnValueChanged" SpinButtonPlacementMode="Hidden" Minimum="0"/>    
                                        <TextBlock x:Name="VideoEndTimeTxt"/>
                                    </StackPanel>
                                </UniformGrid>
                                </ui:Card>
                                <TextBlock Text="Video Encoding" Margin="5,2.5" FontWeight="Medium" FontSize="14" FontFamily="Segoe UI Variable"/>
                                <ui:Card x:Name="VideoFileSize">
                                <StackPanel Orientation="Vertical">
                                    <ui:ToggleSwitch x:Name="EncodeSwitch" IsChecked="True" Checked="EncodeSwitch_OnChecked" Unchecked="EncodeSwitch_OnUnChecked" Content="Encode"/>
                                    <StackPanel x:Name="EncodeSettingsPanel" Visibility="Visible" Orientation="Vertical" Margin="0,10,0,0">
                                        <UniformGrid Columns="2" Margin="0,0,0,10">
                                            <UniformGrid.Resources>
                                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                                </Style>
                                            </UniformGrid.Resources>
                                            <ui:Button Margin="0,0,2.5,0" Click="BitrateBySizeBtn_OnClick" BorderThickness="1" Content="By Size"/>
                                            <ui:Button Margin="2.5,0,0,0" Click="BitrateByBitrateBtn_OnClick" Content="By Bitrate"/>
                                        </UniformGrid>
                                        <StackPanel x:Name="VideoBySizePanel" Visibility="Visible">
                                        <UniformGrid x:Name="VideoFileSizeDefaultBtns" Columns="4">
                                            <UniformGrid.Resources>
                                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                    <Setter Property="Margin" Value="2.5,0"/>
                                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                                </Style>
                                            </UniformGrid.Resources>
                                            <ui:Button Click="VideoBitratePresetbtn_OnClick" Content="10"/>
                                            <ui:Button Click="VideoBitratePresetbtn_OnClick" Content="20"/>
                                            <ui:Button Click='VideoBitratePresetbtn_OnClick' Content="30"/>
                                            <ui:Button Click="VideoBitratePresetbtn_OnClick" Content="40"/>
                                        </UniformGrid>
                                        <Separator Margin="0,2.5"/>
                                        <DockPanel Margin="0,0,0,0">
                                            <CheckBox Checked="CustomSizeCheckBox_OnChecked" Unchecked="CustomSizeCheckBox_OnUnChecked"/>
                                            <ui:NumberBox ValueChanged="CustomSizeNumberBox_OnValueChanged" x:Name="CustomSizeNumberBox" IsEnabled="False" SpinButtonPlacementMode="Hidden" Value="0" Minimum="0"/>
                                        </DockPanel>
                                        </StackPanel>
                                        <StackPanel x:Name="VideoByBitratePanel" Visibility="Collapsed">
                                            <ui:NumberBox ValueChanged="VideoCustomBitrateNumberBox_OnValueChanged" x:Name="VideoCustomBitrateNumberBox" SpinButtonPlacementMode="Hidden" Minimum="0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                </ui:Card>
                                <TextBlock Text="Audio" Margin="5,2.5" FontWeight="Medium" FontSize="14" FontFamily="Segoe UI Variable"/>
                                <ui:Card>
                                    <StackPanel Orientation="Vertical">
                                        <Grid Margin="0,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Margin="0,0,10,0" VerticalAlignment="Center" Text="Audio Bitrate"/>
                                            <ComboBox x:Name="VideoAudioBitrateCombobox" 
                                                      Width="120"
                                                      SelectedIndex="0"
                                                      Grid.Column="1"
                                                      DockPanel.Dock="Right"
                                                      SelectionChanged="VideoAudioBitrateCombobox_OnSelectionChanged">
                                                <ComboBoxItem Content="Default"/>
                                                <ComboBoxItem Content="96"/>
                                                <ComboBoxItem Content="128"/>
                                                <ComboBoxItem Content="192"/>
                                                <ComboBoxItem Content="320"/>
                                                <ComboBoxItem Content="Custom"/>
                                            </ComboBox>
                                        </Grid>
                                        <ui:NumberBox x:Name="VideoAudioCustomBitrateNumberBox" Margin="0,10,0,0" Visibility="Collapsed" ValueChanged="VideoAudioCustomBitrateNumberBox_OnValueChanged" Minimum="0"/>
                                    </StackPanel>
                                </ui:Card>
                                <ui:Card>
                                    <Grid Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Margin="0,0,10,0" VerticalAlignment="Center" Text="Audio Mix Mode"/>
                                        <ComboBox Grid.Column="1" x:Name="VideoAudioMixerCombobox"
                                                  Width="120"
                                                  SelectedIndex="0"
                                                  SelectionChanged="VideoAudioMixerCombobox_OnSelectionChanged">
                                            <ComboBoxItem Content="Don't Mix"/>
                                            <ComboBoxItem Content="Mix All"/>
                                            <ComboBoxItem Content="Mix and keep"/>
                                        </ComboBox>
                                    </Grid>
                                </ui:Card>
                            </StackPanel>
                            <StackPanel x:Name="VideoAfterDataPanel" Visibility="Collapsed" Orientation="Vertical">
                            <TextBlock Text="Output" Margin="5,2.5" FontWeight="Medium" FontSize="14" FontFamily="Segoe UI Variable"/>
                            <ui:Card>
                                <StackPanel>
                                    <TextBlock x:Name="VideoAfterPathTrace" TextWrapping="Wrap" Text="Drop a video to start"/>
                                    <Separator x:Name="OutputNameSeparator" Visibility="Visible" Margin="0,2.5"/>
                                    <StackPanel x:Name="ProgressPanel" Orientation="Vertical" Visibility="Collapsed" Margin="0,0,0,5">
                                        <ProgressBar x:Name="ProgressBar" Minimum="0"
                                                     Maximum="100"
                                                     Padding="0"
                                                     Margin="0,2.5"
                                                     BorderThickness="0"
                                                     Height="5"/>
                                        <UniformGrid Columns="3">
                                            <StackPanel Orientation="Vertical">
                                                <TextBlock Text="FPS"/>
                                                <TextBlock x:Name="VideoStatsFPS" Text="0"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Vertical">
                                                <TextBlock Text="Elapsed"/>
                                                <TextBlock x:Name="VideoStatsElapsed" Text="0"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Vertical">
                                                <TextBlock Text="Remaining"/>
                                                <TextBlock x:Name="VideoStatsET" Text="0"/>
                                            </StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                    <UniformGrid Columns="3">
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="Video"/>
                                            <TextBlock x:Name="VideoAfterBitRate" Text="0Kbps"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="Audio"/>
                                            <TextBlock x:Name="VideoAfterAudioBitrate" Text="0Kbps"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="Total"/>
                                            <TextBlock x:Name="VideoAfterTotalBitrate" Text="0Kbps"/>
                                        </StackPanel>
                                    </UniformGrid>
                                    <UniformGrid Columns="3" Margin="0,5,0,0">
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="Size"/>
                                            <TextBlock x:Name="VideoAfterSize" Text="0MB"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="Streams"/>
                                            <TextBlock x:Name="VideoAfterAudioCount" Text="0"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="Duration"/>
                                            <TextBlock x:Name="VideoAfterDuration" Text="0"/>
                                        </StackPanel>
                                    </UniformGrid>
                                </StackPanel>
                            </ui:Card>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                    <UniformGrid VerticalAlignment="Bottom" Margin="2.5,5" Columns="2">
                        <UniformGrid.Resources>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Margin" Value="2.5,0"/>
                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            </Style>
                        </UniformGrid.Resources>
                        <ui:Button x:Name="MainBtn" IsEnabled="False" Click="MainBtn_OnClick" Content="Encode"/>
                        <ui:Button x:Name="ClearBtn" IsEnabled="False" Click="ClearBtn_OnClick" Content="Clear"/>
                    </UniformGrid>
                </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
